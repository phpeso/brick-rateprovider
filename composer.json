{
    "name": "peso/brick-rateprovider",
    "type": "library",
    "description": "Peso-based RateProvider class for Brick\\Money",
    "keywords": ["currency", "exchange", "conversion", "phpeso", "peso", "brick-money"],
    "homepage": "https://phpeso.readthedocs.io/",
    "license": "MIT",
    "authors": [{
        "name": "Anton Smirnov",
        "role": "developer",
        "homepage": "https://sandfox.me/",
        "email": "sandfox+phpeso@sandfox.me"
    }],
    "support": {
        "issues": "https://github.com/phpeso/brick-rateprovider/issues",
        "source": "https://github.com/phpeso/brick-rateprovider",
        "docs": "https://phpeso.readthedocs.io/"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "Peso\\Brick\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Peso\\Brick\\Tests\\": "tests"
        }
    },
    "require": {
        "php": "^8.2",
        "brick/money": ">=0.10.2 <0.13",
        "peso/core": "^1.1"
    },
    "require-dev": {
        "brick/math": ">=0.14 <0.18",
        "phpunit/phpunit": "^11.5",
        "psy/psysh": "*",
        "sandfox.dev/code-standard": "^1.2025.09.17",
        "squizlabs/php_codesniffer": "*"
    }
}
